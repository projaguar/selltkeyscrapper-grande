{
  "name": "selltkeyscrapper-grande",
  "private": true,
  "version": "1.1.14",
  "description": "selltkeyscrapper grande - AdsPower 브라우저 기반 네이버 크롤러 (Bun 데몬 + 웹 대시보드)",
  "type": "module",
  "scripts": {
    "start": "vite build && bun run src/server.ts",
    "dev": "vite build && bun run --watch src/server.ts",
    "dev:ui": "vite",
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "proxy:import": "bun run scripts/import-proxies.ts",
    "proxy:delete": "bun run scripts/delete-all-proxies.ts",
    "proxy:refresh": "bun run proxy:delete && bun run proxy:import"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "ms": "^2.1.3",
    "puppeteer-core": "^24.35.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "^1.1.14",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
